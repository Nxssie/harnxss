# secrets.fish — REAL secrets, copied to ~/.config/fish/conf.d/secrets.fish
#
# fish auto-sources every ~/.config/fish/conf.d/*.fish at shell start, so these
# env vars are available whenever you launch opencode / codex / etc. from a shell.
# The real file is GITIGNORED — only this .example template is committed.
#
# After editing the real file:  exec fish   (to reload)

# NaN provider (api.nan.builders) — used by opencode.json {env:NAN_API_KEY}
# and codex config.toml env_key = "NAN_API_KEY".
set -gx NAN_API_KEY "sk-xxxxxxxxxxxxxxxxxxxxxxxx"
